<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.estoque.controller.ProdutoController"
            styleClass="app-shell">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" styleClass="janela-topbar">
                <padding><Insets top="16" bottom="16" left="25" right="25"/></padding>
                <Label text="📦  Gerenciamento de Produtos" styleClass="janela-titulo"/>
            </HBox>
            <Region styleClass="faixa-laranja"/>
        </VBox>
    </top>

    <left>
        <ScrollPane fitToWidth="true" styleClass="fundo-area-central">
            <VBox spacing="16" prefWidth="340">
                <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

                <VBox spacing="10" styleClass="card">
                    <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>

                    <Label text="Cadastro de Produto" styleClass="titulo-secao"/>

                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <StackPane styleClass="preview-imagem-container">
                            <Label fx:id="labelSemImagem" text="Sem foto" styleClass="label-sem-imagem"/>
                            <ImageView fx:id="previewImagem" fitWidth="120" fitHeight="120"
                                       preserveRatio="true" visible="false"/>
                        </StackPane>
                        <VBox spacing="8">
                            <Button text="📷 Escolher Foto" onAction="#onEscolherImagem" styleClass="botao-secundario"/>
                            <Label text="JPG, PNG, GIF ou WEBP" styleClass="rotulo-campo"/>
                        </VBox>
                    </HBox>

                    <Label text="Código *" styleClass="rotulo-campo"/>
                    <TextField fx:id="campoCodigo" promptText="Ex: P0004"/>

                    <Label text="Nome *" styleClass="rotulo-campo"/>
                    <TextField fx:id="campoNome" promptText="Nome do produto"/>

                    <Label text="Descrição" styleClass="rotulo-campo"/>
                    <TextArea fx:id="campoDescricao" prefRowCount="2" wrapText="true"/>

                    <Label text="Categoria" styleClass="rotulo-campo"/>
                    <ComboBox fx:id="comboCategoria" maxWidth="Infinity" promptText="Selecione a categoria"/>

                    <Label text="Marca" styleClass="rotulo-campo"/>
                    <ComboBox fx:id="comboMarca" maxWidth="Infinity" promptText="Selecione a marca"/>

                    <Label text="Fornecedor" styleClass="rotulo-campo"/>
                    <ComboBox fx:id="comboFornecedor" maxWidth="Infinity" promptText="Selecione o fornecedor"/>

                    <HBox spacing="10">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Preço de Venda (R\$) *" styleClass="rotulo-campo"/>
                            <TextField fx:id="campoPreco" promptText="Ex: 99.90"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Custo (R\$)" styleClass="rotulo-campo"/>
                            <TextField fx:id="campoCusto" promptText="Ex: 45.00"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="10">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Quantidade *" styleClass="rotulo-campo"/>
                            <TextField fx:id="campoQuantidade" promptText="Ex: 10"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Qtd. Mínima" styleClass="rotulo-campo"/>
                            <TextField fx:id="campoQuantidadeMinima" promptText="Ex: 5"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="8">
                        <Button text="Cadastrar" onAction="#onCadastrar" styleClass="botao-primario" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                        <Button text="Atualizar" onAction="#onAtualizar" styleClass="botao-secundario" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Button text="Remover produto selecionado" onAction="#onRemover" styleClass="botao-perigo" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="10" styleClass="card">
                    <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>

                    <Label text="Entrada Rápida de Estoque" styleClass="titulo-secao"/>
                    <Label text="Some quantidade a um produto já cadastrado." wrapText="true" styleClass="rotulo-campo"/>

                    <Label text="Código do produto" styleClass="rotulo-campo"/>
                    <TextField fx:id="campoCodigoEntrada" promptText="Código já cadastrado"/>

                    <Label text="Quantidade a adicionar" styleClass="rotulo-campo"/>
                    <TextField fx:id="campoQuantidadeEntrada" promptText="Ex: 20"/>

                    <Button text="Dar Entrada no Estoque" onAction="#onDarEntrada" styleClass="botao-primario" maxWidth="Infinity"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </left>

    <center>
        <VBox spacing="14" styleClass="fundo-area-central">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
                <padding><Insets top="12" bottom="12" left="16" right="16"/></padding>
                <Label text="🔎 Buscar:" styleClass="rotulo-campo"/>
                <TextField fx:id="campoBusca" prefWidth="280" promptText="Nome ou código do produto"/>
                <Button text="Buscar" onAction="#onBuscar" styleClass="botao-secundario"/>
            </HBox>

            <Label text="Produtos cadastrados" styleClass="titulo-secao"/>

            <TableView fx:id="tabelaProdutos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colFoto" text="Foto" prefWidth="60" sortable="false"/>
                    <TableColumn fx:id="colCodigo" text="Código" prefWidth="90"/>
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="200"/>
                    <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="120"/>
                    <TableColumn fx:id="colPreco" text="Preço" prefWidth="100"/>
                    <TableColumn fx:id="colQuantidade" text="Qtd." prefWidth="70"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="130"/>
                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>