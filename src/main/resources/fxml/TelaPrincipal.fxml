<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.estoque.controller.TelaPrincipalController"
            styleClass="tela-principal">

    <top>
        <VBox alignment="CENTER" styleClass="cabecalho">
            <padding><Insets top="30" bottom="30"/></padding>
            <Label text="Sistema de Gerenciamento de Estoque" styleClass="titulo-principal"/>
            <Label text="Controle de produtos, vendas e emissão de notas fiscais" styleClass="subtitulo"/>
        </VBox>
    </top>

    <center>
        <HBox alignment="CENTER" spacing="30">
            <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>

            <Button text="📦  Produtos" onAction="#abrirTelaProdutos" styleClass="botao-menu"/>
            <Button text="🧾  Nova Venda" onAction="#abrirTelaVendas" styleClass="botao-menu"/>

        </HBox>
    </center>

</BorderPane>