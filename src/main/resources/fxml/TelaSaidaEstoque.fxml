<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.estoque.controller.SaidaEstoqueController"
            styleClass="app-shell">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" styleClass="janela-topbar">
                <padding><Insets top="16" bottom="16" left="25" right="25"/></padding>
                <Label text="⬆  Saída de Produtos" styleClass="janela-titulo"/>
            </HBox>
            <Region styleClass="faixa-laranja"/>

            <VBox spacing="12" styleClass="fundo-area-central">
                <padding><Insets top="16" bottom="16" left="20" right="20"/></padding>

                <VBox spacing="10" styleClass="card">
                    <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>

                    <Label text="Dados da Saída" styleClass="titulo-secao"/>

                    <Label text="Tipo de Saída *" styleClass="rotulo-campo"/>
                    <ComboBox fx:id="comboTipoSaida" maxWidth="Infinity" promptText="Selecione o motivo"/>

                    <Label text="Observações" styleClass="rotulo-campo"/>
                    <TextArea fx:id="campoObservacoes" prefRowCount="2" wrapText="true"/>

                    <Separator styleClass="separator-orange"/>

                    <Label text="Adicionar produto à saída" styleClass="titulo-secao"/>
                    <HBox spacing="10" alignment="BOTTOM_LEFT">
                        <VBox spacing="4">
                            <Label text="Código do produto" styleClass="rotulo-campo"/>
                            <TextField fx:id="campoCodigoProduto" prefWidth="140"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Quantidade" styleClass="rotulo-campo"/>
                            <TextField fx:id="campoQuantidade" prefWidth="90"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Motivo específico" styleClass="rotulo-campo"/>
                            <TextField fx:id="campoMotivo" prefWidth="180"/>
                        </VBox>
                        <Button text="+ Adicionar" onAction="#onAdicionarItem" styleClass="botao-primario"/>
                        <Button text="Remover Item" onAction="#onRemoverItem" styleClass="botao-perigo"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10" styleClass="fundo-area-central">
            <padding><Insets top="0" bottom="10" left="20" right="20"/></padding>
            <Label text="Produtos desta saída" styleClass="titulo-secao"/>
            <TableView fx:id="tabelaItens" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCodigo" text="Código" prefWidth="90"/>
                    <TableColumn fx:id="colProduto" text="Produto" prefWidth="240"/>
                    <TableColumn fx:id="colQuantidade" text="Qtd." prefWidth="80"/>
                    <TableColumn fx:id="colMotivo" text="Motivo" prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="20" alignment="CENTER_RIGHT" styleClass="rodape-venda">
            <padding><Insets top="18" bottom="18" left="20" right="20"/></padding>
            <Button text="Cancelar" onAction="#onCancelar" styleClass="botao-perigo"/>
            <Button text="✔ Salvar Saída" onAction="#onSalvarSaida" styleClass="botao-primario"/>
        </HBox>
    </bottom>

</BorderPane>