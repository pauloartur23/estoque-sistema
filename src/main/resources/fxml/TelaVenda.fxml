<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.estoque.controller.VendaController"
            styleClass="app-shell">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" styleClass="janela-topbar">
                <padding><Insets top="16" bottom="16" left="25" right="25"/></padding>
                <Label text="🧾  Nova Venda" styleClass="janela-titulo"/>
            </HBox>
            <Region styleClass="faixa-laranja"/>

            <VBox spacing="12" styleClass="fundo-area-central">
                <padding><Insets top="16" bottom="16" left="20" right="20"/></padding>

                <VBox spacing="10" styleClass="card">
                    <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>

                    <Label text="Adicionar item à venda (bipe o código ou digite e aperte Enter)" styleClass="titulo-secao"/>

                    <HBox spacing="10" alignment="BOTTOM_LEFT">
                        <VBox spacing="4">
                            <Label text="Código do produto" styleClass="rotulo-campo"/>
                            <TextField fx:id="campoCodigoProduto" prefWidth="160" onAction="#onAdicionarItem"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Quantidade" styleClass="rotulo-campo"/>
                            <TextField fx:id="campoQuantidade" prefWidth="90" text="1"/>
                        </VBox>
                        <Button text="+ Adicionar Item" onAction="#onAdicionarItem" styleClass="botao-primario"/>
                        <Button text="Remover Item" onAction="#onRemoverItem" styleClass="botao-perigo"/>
                    </HBox>

                    <Separator styleClass="separator-orange"/>

                    <HBox spacing="20" alignment="CENTER_LEFT">
                        <VBox spacing="4">
                            <Label text="Cliente" styleClass="rotulo-campo"/>
                            <ComboBox fx:id="comboCliente" prefWidth="220" promptText="Consumidor Final"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Desconto (R\$)" styleClass="rotulo-campo"/>
                            <HBox spacing="6">
                                <TextField fx:id="campoDesconto" prefWidth="100" text="0"/>
                                <Button text="Aplicar" onAction="#onAplicarDesconto" styleClass="botao-secundario"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <Label text="Forma de Pagamento *" styleClass="rotulo-campo"/>
                    <HBox fx:id="containerFormasPagamento" spacing="10"/>

                    <Label text="Bandeiras aceitas" styleClass="rotulo-campo-pequeno"/>
                    <HBox fx:id="containerBandeiras" spacing="14" alignment="CENTER_LEFT"/>

                    <Label text="Observações" styleClass="rotulo-campo"/>
                    <TextArea fx:id="campoObservacoes" prefRowCount="1" wrapText="true"/>
                </VBox>
            </VBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10" styleClass="fundo-area-central">
            <padding><Insets top="0" bottom="10" left="20" right="20"/></padding>
            <Label text="Itens da venda" styleClass="titulo-secao"/>
            <TableView fx:id="tabelaItens" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCodigo" text="Código" prefWidth="90"/>
                    <TableColumn fx:id="colProduto" text="Produto" prefWidth="240"/>
                    <TableColumn fx:id="colQuantidade" text="Qtd." prefWidth="80"/>
                    <TableColumn fx:id="colPrecoUnitario" text="Preço Unit." prefWidth="130"/>
                    <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="130"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="20" alignment="CENTER_RIGHT" styleClass="rodape-venda">
            <padding><Insets top="18" bottom="18" left="20" right="20"/></padding>
            <Label fx:id="labelTotal" text="Total: R\$ 0.00" styleClass="label-total" HBox.hgrow="ALWAYS"/>
            <Button text="Cancelar Venda" onAction="#onCancelarVenda" styleClass="botao-perigo"/>
            <Button text="✔ Finalizar Venda e Gerar Nota Fiscal" onAction="#onFinalizarVenda" styleClass="botao-primario"/>
        </HBox>
    </bottom>

</BorderPane>