<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.estoque.controller.MarcaController"
            styleClass="app-shell">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" styleClass="janela-topbar">
                <padding><Insets top="16" bottom="16" left="25" right="25"/></padding>
                <Label text="🔖  Marcas" styleClass="janela-titulo"/>
            </HBox>
            <Region styleClass="faixa-laranja"/>
        </VBox>
    </top>

    <left>
        <VBox spacing="10" styleClass="card, fundo-area-central" prefWidth="280">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

            <Label text="Cadastro de Marca" styleClass="titulo-secao"/>

            <Label text="Nome *" styleClass="rotulo-campo"/>
            <TextField fx:id="campoNome" promptText="Ex: Logitech"/>

            <HBox spacing="8">
                <Button text="Salvar" onAction="#onSalvar" styleClass="botao-primario" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                <Button text="Novo" onAction="#onNovo" styleClass="botao-secundario" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>
            <Button text="Remover selecionada" onAction="#onRemover" styleClass="botao-perigo" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="14" styleClass="fundo-area-central">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="Marcas cadastradas" styleClass="titulo-secao"/>
            <TableView fx:id="tabelaMarcas" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="300"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>